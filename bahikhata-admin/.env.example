# BahiKhata Admin — Environment Variables
# Copy this file to .env and fill in the values

# Database (READ-ONLY — use a read replica in production for safety)
# For now, use the same Neon connection string as the main app
# In production: create a read-only user in Neon and use that here
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# NextAuth (use a DIFFERENT secret than the main app!)
NEXTAUTH_URL="http://localhost:3001"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Admin email whitelist (comma-separated)
# Only these emails can access the admin dashboard
ADMIN_EMAILS="rahulkothari677@gmail.com"

# Main app URL (for "Back to App" link)
MAIN_APP_URL="https://bahakhata-pro.vercel.app"

# Optional: IP whitelist (comma-separated, for extra security)
# If set, only these IPs can access the admin app
# ALLOWED_IPS="127.0.0.1,your.home.ip.address"
