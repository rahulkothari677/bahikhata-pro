// BahiKhata Pro — India's Best Ledger App
// Database schema for shop owners: products, parties, transactions, GST, etc.
// Multi-tenant: every model has userId for data isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // Pooled connection (with -pooler) for runtime queries
  directUrl = env("DIRECT_URL") // Direct connection (no -pooler) for migrations
}

// ==================== USERS (Authentication) ====================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String // hashed with bcrypt
  phone         String? // for future phone OTP
  emailVerified DateTime? // for future email verification
  image         String? // profile picture URL
  role          String    @default("owner") // owner | staff
  ownerId       String? // if staff, links to the owner's account
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Staff permissions — JSON object controlling which modules staff can access.
  permissions Json?

  // Subscription / plan
  cancelledAt DateTime?
  plan        String    @default("free") // free | pro | elite
  renewsAt    DateTime?
  trialEndsAt DateTime?

  // 🔒 SECURITY (Audit fix Phase 3.3): tokenVersion for JWT revocation.
  // Incrementing this invalidates ALL existing JWTs for this user (logout all
  // devices, force re-login after password change, kill stolen sessions).
  // The JWT callback in auth.ts compares the token's tokenVersion claim
  // against this DB value on every request — if they differ, the session
  // is treated as invalid.
  tokenVersion Int @default(0)

  // Relations
  products         Product[]
  parties          Party[]
  transactions     Transaction[]
  payments         Payment[]
  settings         Setting[]
  auditLogs        AuditLog[]
  fieldChangeLogs  FieldChangeLog[]
  gstReturns       GstReturn[]
  gstr2bImports    Gstr2bImport[]
  referralsMade    Referral[]       @relation("Referral_referrerIdToUser")
  referralReceived Referral?        @relation("Referral_referredIdToUser")
  subscriptions    Subscription[]
  usageTracking    UsageTracking[]
  shops            Shop[]
  scanComparisons  ScanComparison[]
  aiUsageLogs      AiUsageLog[]
  supportTickets   SupportTicket[]
  npsFeedback      NpsFeedback[]
  invoiceCounter   InvoiceCounter?
  // 🔒 V13 L4: Back-relation for createdByUserId on Transaction
  transactionsCreated Transaction[] @relation("TransactionCreatedBy")

  @@index([plan])
  @@index([createdAt])
  @@index([updatedAt])
}

// ==================== SHOPS (Multi-shop support) ====================
// Each owner can have multiple shops. Products, transactions, parties
// can be tagged with a shopId. When null, shows in all shops (backward compatible).
model Shop {
  id        String   @id @default(cuid())
  userId    String // owner of this shop
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String // e.g. "Sharma Kirana Store"
  gstin     String?
  address   String?
  phone     String?
  state     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ==================== PRODUCTS / INVENTORY ====================
model Product {
  id                String   @id @default(cuid())
  userId            String // owner of this product
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId            String? // multi-shop: null = all shops (backward compatible)
  name              String
  sku               String?
  hsn               String? // HSN/SAC code for GST
  category          String?
  unit              String   @default("pcs") // pcs, kg, ltr, m, box
  purchasePrice     Float    @default(0) // price at which shop owner buys
  salePrice         Float    @default(0) // price at which shop owner sells
  mrp               Float? // MRP printed on product
  gstRate           Float    @default(0) // 0, 5, 12, 18, 28
  // 🔒 V12: When true, salePrice/mrp are INCLUSIVE of GST (the Indian retail
  // norm — MRP is legally GST-inclusive). The sale flow then back-calculates
  // taxable value = price × 100/(100+rate) instead of adding GST on top.
  // Default false = old behaviour (price is taxable value, GST added on top).
  priceIncludesGst  Boolean  @default(false)
  openingStock      Float    @default(0)
  // 🔒 AUDIT FIX H1: Authoritative stock count, maintained transactionally.
  // Was: stock computed at read time (openingStock + purchases - sales) — no
  // guard against overselling, no concurrency control.
  // Now: currentStock is the cached running balance, updated atomically inside
  // the same $transaction as the sale/purchase. On sale: decrement. On purchase:
  // increment. The dashboard reads this directly (no JS recompute).
  currentStock      Float    @default(0)
  lowStockThreshold Float    @default(5)
  notes             String?
  // 🔒 V17 Audit §4.2: GST treatment — distinguishes nil-rated (0% GST but
  // taxable supply), exempt (no GST, not taxable), non-GST (outside GST scope),
  // and taxable (default). Used by GSTR-3B 3.1(c) to properly break out
  // nil-rated vs exempt vs non-GST outward supplies. Before this, exemptValue
  // was hardcoded to 0 because there was no way to mark a product as exempt.
  gstTreatment      String   @default("taxable") // taxable | nil | exempt | nonGst
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactionItems TransactionItem[]

  // Unique SKU per user (not globally)
  @@unique([userId, sku])
  // Performance: list products per user, search by name within user
  @@index([userId, name])
  @@index([userId, category])
  @@index([userId, shopId])
}

// ==================== PARTIES (Customers & Suppliers) ====================
model Party {
  id             String    @id @default(cuid())
  userId         String // owner of this party
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId         String? // multi-shop: null = all shops (backward compatible)
  name           String
  type           String    @default("customer") // customer | supplier | both
  phone          String?
  email          String?
  gstin          String? // GST Identification Number
  address        String?
  state          String? // for intra/inter state GST
  openingBalance Float     @default(0) // positive = they owe us; negative = we owe them
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  // 🔒 AUDIT FIX M7: Soft delete (same as Transaction)
  deletedAt      DateTime?

  transactions Transaction[]
  payments     Payment[]

  // 🔒 V11 §2.2: Indexes — was ZERO indexes, caused full-table scans on every
  // Parties page load and every dashboard load (the receivable/payable query
  // joins Party to Transaction with WHERE p."userId" = ...). At scale this
  // gets linearly slower as the Party table grows across all tenants.
  // Now: two composite indexes matching the actual query patterns.
  @@index([userId, deletedAt]) // list page + join filter (most common query)
  @@index([userId, name]) // list page orders by name
  // V17-Ext Tier 3: GSTIN lookup for GSTR-2B reconciliation (fast supplier matching)
  @@index([userId, gstin])
}

// ==================== TRANSACTIONS (Sales, Purchases, Income, Expense) ====================
model Transaction {
  id              String   @id @default(cuid())
  userId          String // owner of this transaction
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId          String? // multi-shop: null = all shops (backward compatible)
  invoiceNo       String? // bill/invoice number from bill (user-provided OR auto-generated)
  // 🔒 AUDIT FIX M6: Sequential invoice number per user (GST compliance).
  // Auto-generated when the user doesn't provide one. Unique per user so
  // no two transactions share the same invoice number.
  invoiceSequence Int? // auto-incremented per user (1, 2, 3, ...)
  type            String // sale | purchase | income | expense
  partyId         String? // customer for sale, supplier for purchase
  party           Party?   @relation(fields: [partyId], references: [id])
  date            DateTime @default(now())
  subtotal        Float    @default(0) // before tax & discount
  discountAmount  Float    @default(0)
  cgst            Float    @default(0)
  sgst            Float    @default(0)
  igst            Float    @default(0)
  totalAmount     Float    @default(0) // final payable (after round-off)
  // 🔒 V12: Invoice round-off. Indian invoices customarily round the grand
  // total to the nearest rupee with an explicit "Round off" line. This stores
  // the adjustment (e.g. -0.40 or +0.30) so totalAmount == taxable + tax + roundOff
  // and the printed invoice can show it. 0 when round-off is disabled.
  roundOff        Float    @default(0)
  paidAmount      Float    @default(0) // amount actually paid
  paymentMode     String   @default("cash") // cash | upi | card | bank | credit
  isInterState    Boolean  @default(false)
  // V17-Ext Tier 3: Reverse Charge Mechanism (RCM). When true on a purchase,
  // the buyer (shopkeeper) pays GST directly to the government instead of the
  // supplier charging it. Common for: GTA (transport), legal services,
  // unregistered purchases. Affects GSTR-3B sections 3.1(d) + 4(b).
  isReverseCharge Boolean  @default(false)
  notes           String?
  // For income/expense (no items)
  category        String? // e.g. rent, salary, electricity for expenses; commission etc for income
  // Payee info for income/expense (who you paid or received from)
  payeeName       String? // name of person you paid / received from
  payeePhone      String? // mobile number of payee
  // 🔒 V13 L4: Staff accountability — records which user (owner or staff)
  // created this transaction. Null for transactions created before this
  // field was added. Used for audit trail and fraud investigation in
  // multi-user shops. Set automatically from the session in POST handler.
  createdByUserId String?
  createdBy       User?    @relation("TransactionCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // 🔒 IDEMPOTENCY (Audit fix N1): client-generated UUID to prevent duplicate
  // transactions from offline sync replays. When the offline queue replays a
  // mutation that already went through, the server sees the same
  // clientMutationId and returns the existing transaction instead of creating
  // a duplicate. Same pattern as payment idempotency (Phase 1.4).
  clientMutationId String? @unique

  items TransactionItem[]

  // Auto-computed gross profit when type=sale
  grossProfit Float @default(0)

  // 🔒 AUDIT FIX M7: Soft delete for ledger integrity. Was: hard DELETE
  // (permanent, no audit trail). Now: set deletedAt = now() instead of
  // deleting the row. Queries filter WHERE deletedAt IS NULL. This preserves
  // the audit trail (required for GST/tax disputes) and allows "undo delete".
  deletedAt DateTime?

  // V17-Ext Tier 3: Credit/Debit Notes — link to original invoice
  originalTransactionId String?
  originalTransaction   Transaction?  @relation("TransactionReversal", fields: [originalTransactionId], references: [id], onDelete: SetNull)
  reversalTransactions  Transaction[] @relation("TransactionReversal")
  noteType              String?       // 'C' (credit) or 'D' (debit) — only for credit-note/debit-note types
  noteReason            String?       // GST reason: 'post-sale-discount' | 'deficiency' | 'return' | 'price-revision' | 'other'
  affectsStock          Boolean       @default(false) // true only when goods are physically returned

  // 🔒 M6: Unique invoice number per user (GST compliance — no duplicates)
  @@unique([userId, invoiceNo])
  // Performance: list transactions per user filtered by date and/or type
  // Used by: dashboard, ledger (sales/purchases), reports
  @@index([userId, date])
  @@index([userId, type, date])
  @@index([userId, partyId])
  @@index([originalTransactionId])
}

model TransactionItem {
  id                  String      @id @default(cuid())
  transactionId       String
  transaction         Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId           String?
  product             Product?    @relation(fields: [productId], references: [id])
  productName         String // snapshot of name at time of transaction
  quantity            Float       @default(1)
  // 🔒 V12: Snapshot of the unit at time of transaction (kg, gm, ltr, pcs, ...).
  // Was: unit was dropped on save — every historical line was ambiguous
  // ("500 of Tomato" — grams? kilos?). For product-linked lines the server
  // normalizes (quantity, unit) into the product's unit before saving, so
  // quantity × unitPrice is always internally consistent.
  unit                String      @default("pcs")
  unitPrice           Float       @default(0) // price per `unit` (sale or purchase)
  // 🔒 AUDIT FIX M4: Snapshot of purchasePrice at time of sale (COGS).
  // Was: profit calculated from the product's CURRENT purchasePrice —
  // changing it later distorted historical profit. Now: the purchase price
  // is snapshotted here at sale time, so historical profit is immutable.
  purchasePriceAtSale Float       @default(0) // cost at time of sale (for profit calc)
  gstRate             Float       @default(0)
  discountAmount      Float       @default(0) // 🔒 V10 §2.1: per-item discount (proportional share of order-level discount)
  // 🔒 V10 §2.2: per-item GST components — SINGLE SOURCE OF TRUTH for GST.
  // Was: only Transaction header stored cgst/sgst/igst; reports/GSTR recomputed
  // in SQL using a different rounding path → drift between stored and report.
  // Now: every code path (POST, PUT, reports, GSTR, dashboard, invoice PDF)
  // aggregates these stored per-item values. The GST on a transaction is the
  // sum of these three columns across all its items — never recomputed.
  cgst                Float       @default(0)
  sgst                Float       @default(0)
  igst                Float       @default(0)
  total               Float       @default(0) // taxable + cgst + sgst + igst (was qty * unitPrice - discount + gst)

  createdAt DateTime @default(now())

  // ⚡ PERFORMANCE (Audit fix Phase 5): Indexes on foreign keys.
  // Without these, every `include: { items: true }` on Transaction does a
  // FULL TABLE SCAN on TransactionItem. With the index, it's an instant
  // index lookup. This is the #1 missing index in the schema.
  @@index([transactionId])
  @@index([productId])
}

// ==================== PAYMENTS (udhaar settlement — V13 H3) ====================
// 🔒 V13 H3: The Payment model is now ACTIVE (was dead weight before H3).
// Used by:
//   - POST /api/payments — record a receive/pay against a party
//   - GET /api/payments?partyId=xxx — list payments for a party
//   - party-balance.ts — included in balance calculation
//   - PartyProfile.tsx — "Settle" button + Payment History card
model Payment {
  id        String   @id @default(cuid())
  userId    String // owner of this payment
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  partyId   String
  party     Party    @relation(fields: [partyId], references: [id])
  amount    Float
  date      DateTime @default(now())
  mode      String   @default("cash") // cash | upi | card | bank
  type      String   @default("received") // received (from customer) | paid (to supplier)
  notes     String?
  createdAt DateTime @default(now())
  // 🔒 V15 M-3: Soft-delete so deleted receipts stay auditable (disputes / fraud).
  // Hard-deleting a payment silently changes historical balances — exactly the
  // kind of action that should leave an audit trail in a ledger app.
  deletedAt DateTime?

  // ⚡ PERFORMANCE (Audit fix Phase 5): Indexes on foreign keys + hot query
  // patterns. Without these, every payment query does a full table scan.
  @@index([userId, date])
  @@index([partyId, date])
  // 🔒 V15 M-3: Partial index for the common "active payments for this party"
  // query — smaller + faster than a full index because it excludes deleted rows.
  @@index([userId, partyId, deletedAt])
}

// ==================== APP SETTINGS (per user) ====================
model Setting {
  id              String  @id @default(cuid())
  userId          String  @unique // one setting per user
  user            User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName        String  @default("My Shop")
  ownerName       String?
  address         String?
  phone           String?
  gstin           String?
  state           String?
  email           String?
  currency        String  @default("INR")
  language        String  @default("en")
  // Privacy: when true, profit figures are hidden from all UI (dashboard,
  // ledger, transaction detail). Data is still calculated and stored —
  // only the display is hidden. Owner controls this; staff inherits.
  hideProfit      Boolean @default(false)
  // 🔒 V12: When true, the sale grand total is rounded to the nearest rupee
  // (Indian invoice norm) and the adjustment is stored in Transaction.roundOff.
  roundOffEnabled Boolean @default(false)
  // AI Bill Scanner output language: 'original' (keep bill language) | 'en' | 'hi' | 'ta' | 'gu' | 'mr' | 'bn' | 'te' | 'kn' | 'ml' | 'pa'
  scanLang        String  @default("original")
  // AI Voice Entry language: 'original' (keep spoken language, don't translate) | 'en' | 'hi' | 'ta' | 'gu' | 'mr' | 'bn' | 'te' | 'kn' | 'ml' | 'pa'
  // Controls BOTH the speech-recognition locale (e.g. mr-IN) AND the parsed
  // output language. 'original' listens in hi-IN (default) and keeps the
  // spoken language in the parsed result (no English translation).
  voiceLang       String  @default("original")
  // 🔒 V11 STOCK POLICY: Controls whether sales can push stock below 0.
  //   'block' (default) — sale is REJECTED if it would push stock negative.
  //                       The user must record a purchase first or toggle to 'allow'.
  //   'allow'            — sale goes through with a warning (kirana workflow:
  //                       sell first, record purchase later). The warning shows
  //                       in the UI but does NOT block.
  // This field is per-shop (lives on Setting, one per user). The user can
  // toggle it in Settings → "Allow overselling (kirana mode)".
  stockPolicy     String  @default("block")
  // V17-Ext 5.4: Shopkeeper's UPI VPA for udhaar collection links.
  // Used to generate upi://pay?pa=... deep-links in WhatsApp reminders.
  // null = no UPI ID configured (the reminder sends without a pay link).
  upiId           String?
  // 🔒 V17-Ext §5.1: Period lock (financial-year lock). When set, NO writes
  // (create/edit/delete/restore) are allowed to transactions or payments dated
  // on or before this date. Protects filed GST returns from silent alteration.
  // null = no lock (the default — every shop starts unlocked).
  lockedUntil      DateTime?
}

// ==================== ANNOUNCEMENTS (broadcast messages) ====================
model Announcement {
  id        String    @id
  title     String
  message   String
  type      String    @default("info") // info | warning | success | promo
  link      String?
  isActive  Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  createdBy String?

  @@index([isActive, startsAt, endsAt])
}

// ==================== FEATURE FLAGS (remote kill switches) ====================
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique
  enabled     Boolean  @default(true)
  label       String
  description String?
  updatedAt   DateTime @updatedAt
  updatedBy   String?

  @@index([enabled])
}

// ==================== REFERRALS (refer 3 = 1 year free Pro) ====================
model Referral {
  id          String    @id @default(cuid())
  referrerId  String
  referredId  String?   @unique
  code        String    @unique
  status      String    @default("pending") // pending | completed | rewarded
  rewardGiven Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  referrer    User      @relation("Referral_referrerIdToUser", fields: [referrerId], references: [id], onDelete: Cascade)
  referred    User?     @relation("Referral_referredIdToUser", fields: [referredId], references: [id], onDelete: SetNull)

  @@index([referredId])
  @@index([referrerId, status])
}

// ==================== SUBSCRIPTIONS (Razorpay payments) ====================
model Subscription {
  id             String   @id
  userId         String
  plan           String // pro | elite
  status         String   @default("active") // active | cancelled | expired
  amount         Float
  paymentMode    String   @default("razorpay")
  paymentId      String?  @unique // 🔒 IDEMPOTENCY: unique constraint prevents duplicate subscriptions from double-submitted payment verifications (Audit fix Phase 1.4)
  subscriptionId String?
  startDate      DateTime @default(now())
  endDate        DateTime
  createdAt      DateTime @default(now())
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, status])
}

// ==================== USAGE TRACKING (plan limits) ====================
model UsageTracking {
  id           String   @id @default(cuid())
  userId       String
  month        String // YYYY-MM format
  transactions Int      @default(0)
  aiScans      Int      @default(0)
  voiceParses  Int      @default(0)
  products     Int      @default(0)
  updatedAt    DateTime @updatedAt
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

// ==================== PASSWORD RESET TOKENS (C2 audit fix) ====================
// 🔒 SECURITY: Reset tokens are now stored in the DB (not in-memory Map) so
// they survive serverless cold starts and are shared across instances.
// Only the SHA-256 hash is stored — never the raw token.
model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String // the user's email (lowercased)
  tokenHash String    @unique // SHA-256 hash of the raw token (never store raw)
  expiresAt DateTime // 1 hour from creation
  usedAt    DateTime? // null = not yet used; set when consumed (single-use)
  createdAt DateTime  @default(now())

  @@index([email, expiresAt])
  @@index([tokenHash])
}

// ==================== AUDIT LOG (security & compliance) ====================
// Track every important action: logins, data exports, deletes, role changes.
// Used for: security forensics, compliance (DPDP Act), dispute resolution.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String? // user who performed the action (null = unauthenticated attempt)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String // login_success | login_failure | logout | data_export | data_delete | role_change | settings_update | etc.
  entityType String? // product | party | transaction | setting | user | staff
  entityId   String? // ID of the affected entity
  ip         String? // IP address of the actor
  userAgent  String? // browser/device info
  metadata   Json? // any extra context (what changed, what was exported, etc.)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ==================== FIELD-LEVEL AUDIT TRAIL ====================
// V17-Ext 5.1: Every edit to a transaction/payment records who changed
// what field from what to what. This lets you reconstruct what the books
// said at any point in time — fraud defense + court-admissible.
model FieldChangeLog {
  id              String   @id @default(cuid())
  userId          String // shop owner (tenant scope)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entityType      String // transaction | payment
  entityId        String
  fieldName       String // e.g. totalAmount, paidAmount, date
  oldValue        String? // JSON-serialized old value (null = was empty)
  newValue        String? // JSON-serialized new value (null = set to null)
  changedByUserId String? // who made the change (owner or staff). No FK to avoid modifying User model.
  createdAt       DateTime @default(now())

  @@index([userId, entityType, entityId, createdAt])
  @@index([entityId, createdAt])
}

// ==================== GST RETURN (GSTR-3B MONTHLY SNAPSHOT) ====================
// V17-Ext Tier 3: Stores a monthly GSTR-3B snapshot so the user can see
// "what did I file for July?" without recomputing. One snapshot per user
// per month (unique on userId + monthYear). Fields mirror the GSTR-3B form
// sections: 3.1 (outward), 3.1(d) (RCM), 3.1(c) (nil/exempt/non-GST),
// 3.2 (interstate B2C), 4 (ITC), 5 (exempt inward), 6.1 (net payable).
model GstReturn {
  id                          String   @id @default(cuid())
  userId                      String
  user                        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthYear                   String // "072026" (MMYYYY) — matches GSTR-1 fp format
  periodStart                 DateTime // IST first day of month
  periodEnd                   DateTime // IST last day of month
  filingStatus                String   @default("draft") // draft | filed
  filedAt                     DateTime?
  filedByUserId               String? // who marked it as filed

  // Section 3.1(a): Outward taxable supplies (regular sales)
  outwardTaxableValue         Float    @default(0)
  outwardCgst                 Float    @default(0)
  outwardSgst                 Float    @default(0)
  outwardIgst                 Float    @default(0)

  // Section 3.1(d): RCM (reverse charge) outward liability
  rcmTaxableValue             Float    @default(0)
  rcmCgst                     Float    @default(0)
  rcmSgst                     Float    @default(0)
  rcmIgst                     Float    @default(0)

  // Section 3.1(c): Nil-rated + exempt + non-GST outward
  nilRatedValue               Float    @default(0)
  exemptValue                 Float    @default(0)
  nonGstValue                 Float    @default(0)

  // Section 4(a): ITC (input tax credit) from purchases
  itcTaxableValue             Float    @default(0)
  itcCgst                     Float    @default(0)
  itcSgst                     Float    @default(0)
  itcIgst                     Float    @default(0)

  // 🔒 V17 Audit §4.3: Credit/Debit Note breakdown (computed but not stored before).
  // Storing these helps audit/dispute resolution — the filed snapshot now has
  // the full CDN adjustment, not just the net tax payable.
  creditNoteTaxableValue      Float    @default(0)
  creditNoteCgst              Float    @default(0)
  creditNoteSgst              Float    @default(0)
  creditNoteIgst              Float    @default(0)
  debitNoteTaxableValue       Float    @default(0)
  debitNoteCgst               Float    @default(0)
  debitNoteSgst               Float    @default(0)
  debitNoteIgst               Float    @default(0)

  // Section 5: Exempt inward supplies
  exemptInwardValue           Float    @default(0)

  // Section 3.2: Inter-state B2C supplies (unregistered, any amount)
  interstateB2cTaxableValue   Float    @default(0)
  interstateB2cIgst           Float    @default(0)

  // Section 6.1: Net tax payable (output + RCM - ITC)
  netTaxPayable               Float    @default(0)

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([userId, monthYear])
  @@index([userId, periodStart])
}

// ==================== GSTR-2B IMPORT (ITC Reconciliation) ====================
// V17-Ext Tier 3: Stores a monthly GSTR-2B import from the GST portal.
// The user downloads the 2B JSON from the portal and uploads it here.
// We reconcile it against their purchase transactions to determine:
//   - Matched ITC (in both books and 2B = eligible to claim)
//   - Deferred ITC (in books but not in 2B = supplier hasn't filed yet)
//   - Missing purchases (in 2B but not in books = investigate)
model Gstr2bImport {
  id            String          @id @default(cuid())
  userId        String
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  monthYear     String          // "072026" (MMYYYY)
  filingPeriod  String?         // GST portal's fp field
  supplierGstin String?         // taxpayer's own GSTIN (from the 2B file)
  importedAt    DateTime        @default(now())
  rawJson       Json?           // full 2B JSON from portal (for audit/re-import)
  invoiceCount  Int             @default(0)
  taxableTotal  Float           @default(0)
  igstTotal     Float           @default(0)
  cgstTotal     Float           @default(0)
  sgstTotal     Float           @default(0)
  invoices      Gstr2bInvoice[]

  @@unique([userId, monthYear])
  @@index([userId, monthYear])
}

model Gstr2bInvoice {
  id              String       @id @default(cuid())
  gstr2bImportId  String
  gstr2bImport    Gstr2bImport @relation(fields: [gstr2bImportId], references: [id], onDelete: Cascade)
  userId          String       // denormalized for tenant-scoped queries without join
  supplierGstin   String       // ctin from 2B (supplier's GSTIN)
  invoiceNumber   String       // inum from 2B (supplier's invoice number)
  invoiceDate     String?      // idt from 2B (invoice date, raw string from portal)
  taxableValue    Float        @default(0)
  igst            Float        @default(0)
  cgst            Float        @default(0)
  sgst            Float        @default(0)
  totalAmount     Float        @default(0)
  isReverseCharge Boolean      @default(false)
  createdAt       DateTime     @default(now())

  @@index([gstr2bImportId])
  @@index([userId, supplierGstin, invoiceNumber])
  @@index([userId])
}

// ==================== AI SCAN COMPARISONS ====================
// Stores results of side-by-side AI provider tests. Each record is one
// bill image scanned by 1-3 providers (Gemini, OpenAI, Groq). Admins use
// the /settings/ai-comparison page to compare accuracy and pick the best.
model ScanComparison {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The bill image that was scanned
  imageName    String? // filename or label, if user provided one
  imagePreview String // base64 thumbnail (max ~50KB) for display in history

  // Bill type the user said it was
  billType String @default("purchase") // sale | purchase

  // Results from each provider (null if that provider wasn't tested)
  geminiResult Json? // { success, parsed, error, durationMs, tokensUsed }
  openaiResult Json?
  groqResult   Json?

  // Ground truth (what the user manually entered as the correct answer)
  groundTruth Json? // { sellerName, totalAmount, itemsCount, items: [...] }

  // Computed scores per provider (0-100, null if not tested or no ground truth)
  geminiScore Float?
  openaiScore Float?
  groqScore   Float?

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ==================== AI USAGE LOG (cost tracking) ====================
// Every AI call (scan-bill, voice-parse) gets logged here with exact token
// counts and calculated cost. Used by the /settings/ai-usage dashboard to
// show the founder exactly how much each feature costs to run.
model AiUsageLog {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  feature  String // 'scan-bill' | 'voice-parse' | 'scan-compare'
  provider String // 'gemini' | 'openai' | 'groq' | 'vlm' | 'zai-sdk'
  model    String // e.g. 'gemini-2.5-flash', 'llama-4-scout-17b-16e-instruct'

  // Token counts from the AI provider's response
  inputTokens  Int @default(0)
  outputTokens Int @default(0)
  totalTokens  Int @default(0)

  // Cost in INR (calculated at time of call using current pricing)
  // Stored per-call so historical costs are preserved even if prices change
  costInr Float @default(0)

  // Performance + result
  durationMs   Int     @default(0)
  success      Boolean @default(true)
  errorMessage String? // null if success, error text if failed

  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([provider, createdAt])
  @@index([createdAt])
  @@index([feature, provider, createdAt])
}

// ==================== ADMIN PANEL TABLES ====================
// These tables are shared between the Pro app and the admin panel.
//
// 🔒 AUDIT FIX N5: The old comment said these MUST exist here because
// `prisma db push --accept-data-loss` would drop them. But we've now
// switched to `prisma migrate deploy` (Phase 2), which uses versioned
// migration files and NEVER drops tables to "resolve" drift. So the
// old hack is no longer needed.
//
// However, we're keeping these models here for now because:
// 1. The admin panel's prisma client needs to know about these tables
// 2. Both apps share the same database
// 3. Removing them would require the admin panel to have its own
//    separate prisma client + schema (a larger refactor)
//
// In the future, these should be moved to a shared @ekbook/prisma
// package that both apps import. For now, they stay here safely.

