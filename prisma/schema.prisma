// BahiKhata Pro — India's Best Ledger App
// Database schema for shop owners: products, parties, transactions, GST, etc.
// Multi-tenant: every model has userId for data isolation

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== USERS (Authentication) ====================
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String    // hashed with bcrypt
  phone         String?   // for future phone OTP
  emailVerified DateTime? // for future email verification
  image         String?   // profile picture URL
  role          String    @default("owner") // owner | staff
  ownerId       String?   // if staff, links to the owner's account
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Staff permissions — JSON object controlling which modules staff can access.
  permissions   Json?

  // Subscription / plan
  cancelledAt   DateTime?
  plan          String    @default("free") // free | pro | elite
  renewsAt      DateTime?
  trialEndsAt   DateTime?

  // Relations
  products      Product[]
  parties       Party[]
  transactions  Transaction[]
  payments      Payment[]
  settings      Setting[]
  auditLogs     AuditLog[]
  referralsMade Referral[] @relation("Referral_referrerIdToUser")
  referralReceived Referral? @relation("Referral_referredIdToUser")
  subscriptions Subscription[]
  usageTracking  UsageTracking[]
  shops         Shop[]
  scanComparisons ScanComparison[]
  aiUsageLogs    AiUsageLog[]
  supportTickets SupportTicket[]
  npsFeedback   NpsFeedback[]

  @@index([plan])
  @@index([createdAt])
  @@index([updatedAt])
}

// ==================== SHOPS (Multi-shop support) ====================
// Each owner can have multiple shops. Products, transactions, parties
// can be tagged with a shopId. When null, shows in all shops (backward compatible).
model Shop {
  id          String   @id @default(cuid())
  userId      String   // owner of this shop
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String   // e.g. "Sharma Kirana Store"
  gstin       String?
  address     String?
  phone       String?
  state       String?
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

// ==================== PRODUCTS / INVENTORY ====================
model Product {
  id                String   @id @default(cuid())
  userId            String   // owner of this product
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId            String?  // multi-shop: null = all shops (backward compatible)
  name              String
  sku               String?
  hsn               String?  // HSN/SAC code for GST
  category          String?
  unit              String   @default("pcs") // pcs, kg, ltr, m, box
  purchasePrice     Float    @default(0)  // price at which shop owner buys
  salePrice         Float    @default(0)  // price at which shop owner sells
  mrp               Float?   // MRP printed on product
  gstRate           Float    @default(0)  // 0, 5, 12, 18, 28
  openingStock      Float    @default(0)
  lowStockThreshold Float    @default(5)
  notes             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  transactionItems  TransactionItem[]

  // Unique SKU per user (not globally)
  @@unique([userId, sku])
  // Performance: list products per user, search by name within user
  @@index([userId, name])
  @@index([userId, category])
  @@index([userId, shopId])
}

// ==================== PARTIES (Customers & Suppliers) ====================
model Party {
  id              String   @id @default(cuid())
  userId          String   // owner of this party
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId          String?  // multi-shop: null = all shops (backward compatible)
  name            String
  type            String   @default("customer") // customer | supplier | both
  phone           String?
  email           String?
  gstin           String?  // GST Identification Number
  address         String?
  state           String?  // for intra/inter state GST
  openingBalance  Float    @default(0) // positive = they owe us; negative = we owe them
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  transactions    Transaction[]
  payments        Payment[]
}

// ==================== TRANSACTIONS (Sales, Purchases, Income, Expense) ====================
model Transaction {
  id             String   @id @default(cuid())
  userId         String   // owner of this transaction
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopId         String?  // multi-shop: null = all shops (backward compatible)
  invoiceNo      String?  // bill/invoice number from bill
  type           String   // sale | purchase | income | expense
  partyId        String?  // customer for sale, supplier for purchase
  party          Party?   @relation(fields: [partyId], references: [id])
  date           DateTime @default(now())
  subtotal       Float    @default(0)  // before tax & discount
  discountAmount Float    @default(0)
  cgst           Float    @default(0)
  sgst           Float    @default(0)
  igst           Float    @default(0)
  totalAmount    Float    @default(0)  // final payable
  paidAmount     Float    @default(0)  // amount actually paid
  paymentMode    String   @default("cash") // cash | upi | card | bank | credit
  isInterState   Boolean  @default(false)
  notes          String?
  // For income/expense (no items)
  category       String?  // e.g. rent, salary, electricity for expenses; commission etc for income
  // Payee info for income/expense (who you paid or received from)
  payeeName      String?  // name of person you paid / received from
  payeePhone     String?  // mobile number of payee
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  items          TransactionItem[]

  // Auto-computed gross profit when type=sale
  grossProfit    Float    @default(0)

  // Performance: list transactions per user filtered by date and/or type
  // Used by: dashboard, ledger (sales/purchases), reports
  @@index([userId, date])
  @@index([userId, type, date])
  @@index([userId, partyId])
}

model TransactionItem {
  id             String   @id @default(cuid())
  transactionId  String
  transaction    Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product?  @relation(fields: [productId], references: [id])
  productName    String   // snapshot of name at time of transaction
  quantity       Float    @default(1)
  unitPrice      Float    @default(0)  // price per unit (sale or purchase)
  gstRate        Float    @default(0)
  discountAmount Float    @default(0)
  total          Float    @default(0)  // qty * unitPrice - discount + gst

  createdAt      DateTime @default(now())
}

// ==================== PAYMENTS (separate from transaction totals) ====================
model Payment {
  id          String   @id @default(cuid())
  userId      String   // owner of this payment
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  partyId     String
  party       Party    @relation(fields: [partyId], references: [id])
  amount      Float
  date        DateTime @default(now())
  mode        String   @default("cash") // cash | upi | card | bank
  type        String   @default("received") // received (from customer) | paid (to supplier)
  notes       String?
  createdAt   DateTime @default(now())
}

// ==================== APP SETTINGS (per user) ====================
model Setting {
  id        String   @id @default(cuid())
  userId    String   @unique // one setting per user
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  shopName  String   @default("My Shop")
  ownerName String?
  address   String?
  phone     String?
  gstin     String?
  state     String?
  email     String?
  currency  String   @default("INR")
  language  String   @default("en")
  // Privacy: when true, profit figures are hidden from all UI (dashboard,
  // ledger, transaction detail). Data is still calculated and stored —
  // only the display is hidden. Owner controls this; staff inherits.
  hideProfit Boolean @default(false)
}

// ==================== ANNOUNCEMENTS (broadcast messages) ====================
model Announcement {
  id        String    @id
  title     String
  message   String
  type      String    @default("info") // info | warning | success | promo
  link      String?
  isActive  Boolean   @default(true)
  startsAt  DateTime  @default(now())
  endsAt    DateTime?
  createdAt DateTime  @default(now())
  createdBy String?

  @@index([isActive, startsAt, endsAt])
}

// ==================== FEATURE FLAGS (remote kill switches) ====================
model FeatureFlag {
  id          String   @id
  key         String   @unique
  enabled     Boolean  @default(true)
  label       String
  description String?
  updatedAt   DateTime
  updatedBy   String?

  @@index([enabled])
}

// ==================== REFERRALS (refer 3 = 1 year free Pro) ====================
model Referral {
  id          String    @id
  referrerId  String
  referredId  String?   @unique
  code        String    @unique
  status      String    @default("pending") // pending | completed | rewarded
  rewardGiven Boolean   @default(false)
  createdAt   DateTime  @default(now())
  completedAt DateTime?
  referrer    User      @relation("Referral_referrerIdToUser", fields: [referrerId], references: [id], onDelete: Cascade)
  referred    User?     @relation("Referral_referredIdToUser", fields: [referredId], references: [id])

  @@index([referredId])
  @@index([referrerId, status])
}

// ==================== SUBSCRIPTIONS (Razorpay payments) ====================
model Subscription {
  id             String   @id
  userId         String
  plan           String   // pro | elite
  status         String   @default("active") // active | cancelled | expired
  amount         Float
  paymentMode    String   @default("razorpay")
  paymentId      String?
  subscriptionId String?
  startDate      DateTime @default(now())
  endDate        DateTime
  createdAt      DateTime @default(now())
  User           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, createdAt])
  @@index([userId, status])
}

// ==================== USAGE TRACKING (plan limits) ====================
model UsageTracking {
  id           String   @id
  userId       String
  month        String   // YYYY-MM format
  transactions Int      @default(0)
  aiScans      Int      @default(0)
  voiceParses  Int      @default(0)
  products     Int      @default(0)
  updatedAt    DateTime
  User         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@index([userId, month])
}

// ==================== AUDIT LOG (security & compliance) ====================
// Track every important action: logins, data exports, deletes, role changes.
// Used for: security forensics, compliance (DPDP Act), dispute resolution.
model AuditLog {
  id         String   @id @default(cuid())
  userId     String?  // user who performed the action (null = unauthenticated attempt)
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     String   // login_success | login_failure | logout | data_export | data_delete | role_change | settings_update | etc.
  entityType String?  // product | party | transaction | setting | user | staff
  entityId   String?  // ID of the affected entity
  ip         String?  // IP address of the actor
  userAgent  String?  // browser/device info
  metadata   Json?    // any extra context (what changed, what was exported, etc.)
  createdAt  DateTime @default(now())

  @@index([userId, createdAt])
  @@index([action, createdAt])
}

// ==================== AI SCAN COMPARISONS ====================
// Stores results of side-by-side AI provider tests. Each record is one
// bill image scanned by 1-3 providers (Gemini, OpenAI, Groq). Admins use
// the /settings/ai-comparison page to compare accuracy and pick the best.
model ScanComparison {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // The bill image that was scanned
  imageName     String?  // filename or label, if user provided one
  imagePreview  String   // base64 thumbnail (max ~50KB) for display in history

  // Bill type the user said it was
  billType      String   @default("purchase") // sale | purchase

  // Results from each provider (null if that provider wasn't tested)
  geminiResult  Json?    // { success, parsed, error, durationMs, tokensUsed }
  openaiResult  Json?
  groqResult    Json?

  // Ground truth (what the user manually entered as the correct answer)
  groundTruth   Json?    // { sellerName, totalAmount, itemsCount, items: [...] }

  // Computed scores per provider (0-100, null if not tested or no ground truth)
  geminiScore   Float?
  openaiScore   Float?
  groqScore     Float?

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

// ==================== AI USAGE LOG (cost tracking) ====================
// Every AI call (scan-bill, voice-parse) gets logged here with exact token
// counts and calculated cost. Used by the /settings/ai-usage dashboard to
// show the founder exactly how much each feature costs to run.
model AiUsageLog {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  feature       String   // 'scan-bill' | 'voice-parse' | 'scan-compare'
  provider      String   // 'gemini' | 'openai' | 'groq' | 'vlm' | 'zai-sdk'
  model         String   // e.g. 'gemini-2.5-flash', 'llama-4-scout-17b-16e-instruct'

  // Token counts from the AI provider's response
  inputTokens   Int      @default(0)
  outputTokens  Int      @default(0)
  totalTokens   Int      @default(0)

  // Cost in INR (calculated at time of call using current pricing)
  // Stored per-call so historical costs are preserved even if prices change
  costInr       Float    @default(0)

  // Performance + result
  durationMs    Int      @default(0)
  success       Boolean  @default(true)
  errorMessage  String?  // null if success, error text if failed

  createdAt     DateTime @default(now())

  @@index([userId, createdAt])
  @@index([feature, createdAt])
  @@index([provider, createdAt])
  @@index([createdAt])
  @@index([feature, provider, createdAt])
}


// ==================== ADMIN PANEL TABLES ====================
// These tables are owned by the admin panel (bahikhata-admin repo) but
// MUST exist in the main app's schema too. Otherwise, when the main app
// runs `prisma db push` during Vercel builds, it drops these tables —
// wiping all admin accounts on every deploy.
//
// DO NOT remove these models from this file.

model AdminUser {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String
  password      String
  role          String    @default("admin")
  totpSecret    String?
  totpEnabled   Boolean   @default(false)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  lastLoginIp   String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  adminActions  AdminAction[]

  @@index([email])
  @@index([isActive])
}

model AdminAction {
  id            String   @id @default(cuid())
  adminId       String
  admin         AdminUser @relation(fields: [adminId], references: [id], onDelete: Cascade)
  action        String
  targetType    String?
  targetId      String?
  description   String
  metadata      Json?
  ip            String?
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([adminId, createdAt])
  @@index([action, createdAt])
  @@index([targetType, targetId])
}

// ==================== SUPPORT TICKETS (admin panel) ====================
model SupportTicket {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject     String
  message     String
  category    String    @default("general")
  priority    String    @default("medium")
  status      String    @default("open")
  assignedTo  String?
  response    String?
  resolvedAt  DateTime?
  resolvedBy  String?
  userEmail   String?
  userAgent   String?
  appVersion  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([status, priority, createdAt])
  @@index([userId, createdAt])
  @@index([assignedTo, status])
}

// ==================== NPS FEEDBACK (admin panel) ====================
model NpsFeedback {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  score       Int
  feedback    String?
  category    String?
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([score])
}

// ==================== DAILY STATS (admin panel — pre-computed KPIs) ====================
model DailyStats {
  id              String   @id @default(cuid())
  date            DateTime @unique
  totalUsers      Int      @default(0)
  newUsers        Int      @default(0)
  activeUsers     Int      @default(0)
  payingUsers     Int      @default(0)
  mrr             Float    @default(0)
  newMrr          Float    @default(0)
  churnedMrr      Float    @default(0)
  arr             Float    @default(0)
  totalGmv        Float    @default(0)
  totalTxns       Int      @default(0)
  salesCount      Int      @default(0)
  purchasesCount  Int      @default(0)
  aiCalls         Int      @default(0)
  aiCostInr       Float    @default(0)
  aiScans         Int      @default(0)
  voiceParses     Int      @default(0)
  computedAt      DateTime @default(now())
  @@index([date])
}

// ==================== USER SEGMENTS CACHE (admin panel) ====================
model UserSegmentCache {
  id          String   @id @default(cuid())
  userId      String
  segmentId   String
  computedAt  DateTime @default(now())
  @@unique([userId, segmentId])
  @@index([segmentId])
  @@index([userId])
}

// ==================== CREDIT SCORE CACHE (admin panel) ====================
model CreditScoreCache {
  id              String   @id @default(cuid())
  userId          String   @unique
  score           Int
  band            String
  avgMonthlySales Float    @default(0)
  totalSales6Mo   Float    @default(0)
  activeMonths    Int      @default(0)
  collectionRate  Float    @default(0)
  businessAgeDays Int      @default(0)
  productCount    Int      @default(0)
  partyCount      Int      @default(0)
  hasGstData      Boolean  @default(false)
  recommendation  String?
  computedAt      DateTime @default(now())
  @@index([score])
  @@index([band])
}

// ==================== NOTIFICATION TEMPLATES (shared with admin) ====================
model NotificationTemplate {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("general")
  channel     String                          // sms | email | push
  subject     String?
  body        String   @db.Text
  variables   String   @default("[]") @db.Text
  language    String   @default("en")
  status      String   @default("draft")
  version     Int      @default(1)
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channel, status])
  @@index([category, status])
  @@index([status])
}

// ==================== NOTIFICATION LOG (shared with admin) ====================
model NotificationLog {
  id            String   @id @default(cuid())
  userId        String?
  recipient     String
  templateId    String?
  templateName  String?
  channel       String
  subject       String?
  body          String   @db.Text
  status        String   @default("pending")
  provider      String?
  providerMessageId String?
  errorMessage  String?
  sentBy        String?
  sentAt        DateTime @default(now())
  category      String   @default("general")

  @@index([userId, sentAt])
  @@index([channel, status, sentAt])
  @@index([status, sentAt])
  @@index([sentAt])
}

// ==================== CAMPAIGNS (shared with admin) ====================
model Campaign {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  status          String   @default("draft")
  targetSegmentId String?
  targetUserIds   String   @default("[]") @db.Text
  startAt         DateTime?
  endAt           DateTime?
  totalRecipients Int      @default(0)
  totalSent       Int      @default(0)
  totalFailed     Int      @default(0)
  totalSkipped    Int      @default(0)
  currentStep     Int      @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  startedAt       DateTime?
  completedAt     DateTime?
  steps           CampaignStep[]

  @@index([status, startAt])
  @@index([createdBy])
}

model CampaignStep {
  id              String   @id @default(cuid())
  campaignId      String
  campaign        Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  stepNumber      Int
  templateId      String
  templateName    String?
  delayMinutes    Int      @default(0)
  status          String   @default("pending")
  scheduledAt     DateTime?
  sentAt          DateTime?
  recipientCount  Int      @default(0)
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  skippedCount    Int      @default(0)
  errorMessage    String?

  @@index([campaignId, stepNumber])
  @@index([status, scheduledAt])
}

// ==================== STATUS PAGE / INCIDENTS (shared with admin) ====================
model Incident {
  id          String   @id @default(cuid())
  title       String
  description String   @db.Text
  severity    String   @default("minor")
  status      String   @default("investigating")
  service     String   @default("all")
  startedAt   DateTime @default(now())
  resolvedAt  DateTime?
  createdBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  updates     IncidentUpdate[]

  @@index([status, startedAt])
  @@index([service, status])
}

model IncidentUpdate {
  id          String   @id @default(cuid())
  incidentId  String
  incident    Incident @relation(fields: [incidentId], references: [id], onDelete: Cascade)
  message     String   @db.Text
  status      String
  createdBy   String?
  createdAt   DateTime @default(now())

  @@index([incidentId, createdAt])
}

// ==================== ANOMALY DETECTION (shared with admin) ====================
model Anomaly {
  id            String   @id @default(cuid())
  metric        String
  metricLabel   String
  direction     String
  severity      String   @default("medium")
  status        String   @default("open")
  currentValue  Float
  baselineValue Float
  baselineStdDev Float
  zScore        Float
  baselineDays  Int      @default(30)
  detectedAt    DateTime @default(now())
  windowStart   DateTime
  windowEnd     DateTime
  acknowledgedBy String?
  acknowledgedAt DateTime?
  resolvedBy     String?
  resolvedAt     DateTime?
  adminNote      String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([status, detectedAt])
  @@index([metric, detectedAt])
  @@index([detectedAt])
}

// ==================== CONFIGURABLE FRAUD RULES (shared with admin) ====================
model FraudRule {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  metric          String
  operator        String
  threshold       Float
  windowMinutes   Int?
  userAgeMinutes  Int?
  enabled         Boolean  @default(true)
  severity        String   @default("medium")
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  alerts          FraudAlert[]

  @@index([enabled, metric])
}

model FraudAlert {
  id              String   @id @default(cuid())
  ruleId          String
  rule            FraudRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  userId          String
  userName        String?
  userEmail       String?
  metricValue     Float
  threshold       Float
  status          String   @default("open")
  adminNote       String?  @db.Text
  detectedAt      DateTime @default(now())
  acknowledgedBy  String?
  acknowledgedAt  DateTime?
  resolvedBy      String?
  resolvedAt      DateTime?

  @@index([status, detectedAt])
  @@index([ruleId, detectedAt])
  @@index([userId, detectedAt])
}

// ==================== PARTNER MANAGEMENT (shared with admin) ====================
model Partner {
  id                  String   @id @default(cuid())
  name                String
  type                String   @default("nbfc")
  status              String   @default("onboarding")
  contactName         String?
  contactEmail        String?
  contactPhone        String?
  website             String?
  apiBaseUrl          String?
  webhookUrl          String?
  revenueSharePct     Float    @default(0)
  totalLeadsSent      Int      @default(0)
  totalRevenueShared  Float    @default(0)
  contractStartAt     DateTime?
  contractEndAt       DateTime?
  notes               String?  @db.Text
  createdBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([type, status])
  @@index([status])
}

// ==================== API KEYS (shared with admin) ====================
model ApiKey {
  id            String    @id @default(cuid())
  partnerId     String?
  name          String
  keyHash       String   @unique
  keyPrefix     String
  scopes        String   @default("[]") @db.Text
  status        String   @default("active")
  expiresAt     DateTime?
  lastUsedAt    DateTime?
  usageCount    Int      @default(0)
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([partnerId, status])
  @@index([status])
  @@index([keyHash])
}

// ==================== WEBHOOK MANAGEMENT (shared with admin) ====================
model WebhookEndpoint {
  id            String   @id @default(cuid())
  partnerId     String
  url           String
  secret        String?
  events        String   @default("[]") @db.Text
  status        String   @default("active")
  description   String?
  totalSent     Int      @default(0)
  totalSuccess  Int      @default(0)
  totalFailed   Int      @default(0)
  lastSentAt    DateTime?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([partnerId, status])
  @@index([status])
}

model WebhookDelivery {
  id              String   @id @default(cuid())
  endpointId      String
  eventType       String
  payload         String   @db.Text
  status          String   @default("pending")
  attemptCount    Int      @default(0)
  maxAttempts     Int      @default(3)
  responseStatus  Int?
  responseBody    String?  @db.Text
  errorMessage    String?
  firstAttemptAt  DateTime?
  lastAttemptAt   DateTime?
  nextRetryAt     DateTime?
  deliveredAt     DateTime?
  createdAt       DateTime @default(now())

  @@index([endpointId, status, createdAt])
  @@index([status, nextRetryAt])
  @@index([createdAt])
}

// ==================== REVENUE RECOGNITION (shared with admin) ====================
model RevenueSchedule {
  id              String   @id @default(cuid())
  subscriptionId  String
  userId          String
  plan            String
  amount          Float
  periodStart     DateTime
  periodEnd       DateTime
  status          String   @default("pending")
  recognizedAt    DateTime?
  createdAt       DateTime @default(now())

  @@index([status, periodStart])
  @@index([userId, periodStart])
  @@index([subscriptionId])
  @@index([periodStart])
}

// ==================== A/B TESTING (shared with admin) ====================
model Experiment {
  id              String   @id @default(cuid())
  name            String
  description     String?  @db.Text
  status          String   @default("draft")
  metric          String
  metricGoal      String  @default("increase")
  targetEvent     String?
  trafficPct      Int      @default(100)
  variants        String   @default("[]") @db.Text
  startAt         DateTime?
  endAt           DateTime?
  winnerVariant   String?
  conclusion      String?  @db.Text
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, startAt])
}

model ExperimentAssignment {
  id              String   @id @default(cuid())
  experimentId    String
  userId          String
  variantKey      String
  assignedAt      DateTime @default(now())
  convertedAt     DateTime?
  conversionValue Float    @default(0)

  @@unique([experimentId, userId])
  @@index([experimentId, variantKey])
  @@index([userId, experimentId])
  @@index([convertedAt])
}

// ==================== COMPETITOR MONITORING (shared with admin) ====================
model Competitor {
  id              String   @id @default(cuid())
  name            String
  website         String?
  description     String?  @db.Text
  freePrice       String?
  proPrice        String?
  elitePrice      String?
  features        String   @default("{}") @db.Text
  targetMarket    String?
  usp             String?  @db.Text
  weaknesses      String?  @db.Text
  status          String   @default("active")
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
}

model CompetitorUpdate {
  id              String   @id @default(cuid())
  competitorId    String
  field           String
  oldValue        String?  @db.Text
  newValue        String?  @db.Text
  note            String?  @db.Text
  updatedBy       String?
  createdAt       DateTime @default(now())

  @@index([competitorId, createdAt])
}

// ==================== BULK OPERATIONS v2 (shared with admin) ====================
model BulkJob {
  id              String   @id @default(cuid())
  name            String
  action          String
  targetType      String   @default("user")
  targetCriteria  String   @default("{}") @db.Text
  actionParams    String   @default("{}") @db.Text
  status          String   @default("scheduled")
  scheduledAt     DateTime
  startedAt       DateTime?
  completedAt     DateTime?
  totalTargets    Int      @default(0)
  processedCount  Int      @default(0)
  successCount    Int      @default(0)
  failedCount     Int      @default(0)
  errorMessage    String?  @db.Text
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status, scheduledAt])
  @@index([action, status])
}

// ==================== NPS SURVEY CONFIG (shared with admin) ====================
model NpsSurveyConfig {
  id              String   @id @default(cuid())
  name            String
  triggerType     String
  triggerValue    Int
  question        String   @default("How likely are you to recommend BahiKhata Pro to a friend or colleague?")
  cooldownDays    Int      @default(90)
  targetPlans     String   @default("all")
  enabled         Boolean  @default(true)
  priority        Int      @default(1)
  timesShown      Int      @default(0)
  timesResponded  Int      @default(0)
  createdBy       String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([enabled, triggerType])
}

// ==================== DATA EXPORT CENTER (shared with admin) ====================
model DataExportRequest {
  id              String   @id @default(cuid())
  type            String
  format          String   @default("csv")
  status          String   @default("pending")
  userId          String?
  customQuery     String?  @db.Text
  fileName        String?
  fileSizeBytes   Int      @default(0)
  rowCount        Int      @default(0)
  errorMessage    String?  @db.Text
  requestedBy     String?
  processedBy     String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?
  expiresAt       DateTime?

  @@index([status, createdAt])
  @@index([type, status])
}

// ==================== PREDICTIVE CHURN MODEL (shared with admin) ====================
model ChurnPrediction {
  id              String   @id @default(cuid())
  userId          String   @unique
  userName        String?
  userEmail       String?
  userPlan        String?
  riskScore       Int
  riskLevel       String
  inactivityScore Int      @default(0)
  engagementScore Int      @default(0)
  aiUsageScore    Int      @default(0)
  planScore       Int      @default(0)
  ageScore        Int      @default(0)
  supportScore    Int      @default(0)
  recommendedAction String?
  computedAt      DateTime @default(now())

  @@index([riskLevel, riskScore])
  @@index([userPlan, riskLevel])
}

// ==================== SUPPLIER INTELLIGENCE (shared with admin) ====================
model SupplierReport {
  id              String   @id @default(cuid())
  name            String
  type            String
  partnerId       String?
  status          String   @default("generated")
  summary         String?  @db.Text
  data            String   @default("{}") @db.Text
  dataPoints      Int      @default(0)
  userCount       Int      @default(0)
  priceInr        Float    @default(0)
  period          String?
  generatedBy     String?
  createdAt       DateTime @default(now())
  deliveredAt     DateTime?

  @@index([type, status])
  @@index([partnerId, status])
}
