# Database (Neon PostgreSQL)
DATABASE_URL="postgresql://username:password@host/database?sslmode=require"

# NextAuth.js
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"

# Cloudinary (bill image storage)
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# =====================================================================
# AI Bill Scanner (VLM) — Multi-Provider Setup
# =====================================================================
#
# PRIMARY provider (used for production scans).
# Supports any OpenAI-compatible Vision API. Pick ONE of:
#
#   1. Google Gemini (RECOMMENDED — best Hindi accuracy, cheapest):
#      Get key from: https://aistudio.google.com/apikey  (NOT Google Cloud Console!)
#      VLM_API_KEY="your-gemini-key"
#      VLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
#      VLM_MODEL="gemini-2.5-flash"
#
#   2. OpenAI (good accuracy, slightly more expensive):
#      Get key from: https://platform.openai.com/api-keys
#      VLM_API_KEY="your-openai-key"
#      VLM_BASE_URL="https://api.openai.com/v1"
#      VLM_MODEL="gpt-4o-mini"
#
#   3. Groq (fastest, free tier, weaker Hindi):
#      Get key from: https://console.groq.com/keys
#      VLM_API_KEY="your-groq-key"
#      VLM_BASE_URL="https://api.groq.com/openai/v1"
#      VLM_MODEL="llama-3.2-90b-vision-preview"
#
# NOTE: gemini-1.5-flash was DEPRECATED by Google in late 2025.
# Use gemini-2.5-flash (or gemini-2.0-flash) instead. The previous
# "Gemini didn't work" issue was caused by the deprecated model name.
#
# NOTE: For Gemini, the base URL MUST have a trailing slash.
VLM_API_KEY=""
VLM_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai/"
VLM_MODEL="gemini-2.5-flash"

# =====================================================================
# AI Provider Comparison Tool (optional — for the /settings/ai-comparison page)
# =====================================================================
#
# Set these to enable side-by-side accuracy testing of all 3 providers.
# Get each key from the URLs above. All 3 are optional — the comparison
# page will skip any provider whose key is missing.
GEMINI_API_KEY=""
OPENAI_API_KEY=""
GROQ_API_KEY=""

# =====================================================================
# Razorpay (payment gateway — for Pro/Elite subscriptions)
# =====================================================================
# Get keys from: https://dashboard.razorpay.com/app/keys
# Use TEST keys for development, LIVE keys for production.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# =====================================================================
# Sentry (error monitoring — optional but recommended for production)
# =====================================================================
# Get DSN from: https://sentry.io/settings/projects/bahikhata-pro/keys/
# If not set, Sentry is a no-op (safe for local dev).
# NEXT_PUBLIC_SENTRY_DSN is needed for client-side error tracking.
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
SENTRY_AUTH_TOKEN=""

# =====================================================================
# Email (Resend — for password reset emails)
# =====================================================================
# 🔒 AUDIT FIX V5 HB: Required so password reset actually sends emails.
# Without these, the reset endpoint stores a token but no email is sent —
# users get silently locked out. The server logs a founder alert instead.
#
# Setup (5 minutes):
#   1. Sign up at https://resend.com (free tier: 3,000 emails/month)
#   2. Verify your sending domain (e.g. ekbook.app) in Resend dashboard
#   3. Copy your API key from https://resend.com/api-keys
#   4. Set the three vars below in Vercel → Settings → Environment Variables
#
# Free tier is more than enough — password resets are rare events.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="EkBook <noreply@ekbook.app>"
# Founder alert email — receives a notification when a password reset is
# requested but no provider is configured (so you can manually help the user).
# If not set, alerts are logged to the server console only.
FOUNDER_ALERT_EMAIL=""


# =====================================================================
# CRON_SECRET (V20-018) — protects the nightly reconciliation cron job
# =====================================================================
# The /api/cron/nightly-reconciliation endpoint runs reconciliation checks
# across ALL users. To prevent anyone from triggering this heavy DB scan,
# the endpoint requires `Authorization: Bearer <CRON_SECRET>`.
#
# Generate a secret: openssl rand -hex 32
# Set the SAME value in:
#   1. Vercel → Settings → Environment Variables → CRON_SECRET
#   2. GitHub repo → Settings → Secrets and variables → Actions → CRON_SECRET
#
# The GitHub Actions workflow (.github/workflows/nightly-reconciliation.yml)
# uses the GitHub secret to call the endpoint. The endpoint verifies against
# the Vercel env var. They must match.
CRON_SECRET=""

# =====================================================================
# 🔒 V26 Phase 7 — Razorpay Webhook (CRITICAL for production)
# =====================================================================
# The webhook route (/api/payment/webhook) handles payment.captured and
# order.paid events. If the client dies between payment and /verify, the
# webhook is the ONLY thing that upgrades the user's plan.
#
# ⚠️ FAIL-CLOSED: If RAZORPAY_WEBHOOK_SECRET is not set, the webhook
# rejects ALL incoming webhooks. Users whose phone dies mid-payment will
# stay on the free plan until you manually fix them.
#
# Setup:
#   1. Generate a webhook secret in the Razorpay dashboard:
#      Settings → Webhooks → Add New Webhook
#   2. Webhook URL: https://your-domain.com/api/payment/webhook
#   3. Events: payment.captured, order.paid
#   4. Copy the secret Razorpay generates → set it here
RAZORPAY_WEBHOOK_SECRET=""

# =====================================================================
# 🔒 V26 Phase 7 — Upstash Redis (rate limiting)
# =====================================================================
# Rate limiting uses Upstash Redis in production. Without these, rate
# limiting falls back to per-instance in-memory (mostly decorative on
# serverless — each function instance has its own counter).
#
# Setup:
#   1. Create a free Redis database at https://upstash.com
#   2. Copy the REST URL and token from the database dashboard
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# =====================================================================
# 🔒 V26 Phase 7 — Founder emails allowlist
# =====================================================================
# Comma-separated list of email addresses that get founder access
# (unlimited AI scans, AI Usage page, debug endpoints, etc.)
# Example: "founder@ekbook.app,cofounder@ekbook.app"
FOUNDER_EMAILS=""

# =====================================================================
# 🔒 V26 Phase 7 — Repair endpoints (DO NOT SET IN PRODUCTION)
# =====================================================================
# If set to "true", debug repair endpoints (/api/debug/*) are enabled.
# These endpoints can modify payment amounts and party balances.
# Leave BLANK in production. Only set to "true" for one-off local repairs.
ALLOW_REPAIR_ENDPOINTS=""

# =====================================================================
# 🔒 V26 Phase 7 — App URL (for GitHub Actions cron)
# =====================================================================
# The nightly reconciliation GitHub Action needs to know the production
# URL to call the cron endpoint. Set this to your Vercel domain.
APP_URL="https://your-app.vercel.app"
