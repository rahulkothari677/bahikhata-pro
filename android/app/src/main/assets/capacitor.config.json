{
  "appId": "pro.bahikhata.app",
  "appName": "BahiKhata Pro",
  "webDir": "out",
  "bundledWebRuntime": false,
  "server": {
    "url": "https://bahikhata-pro.vercel.app",
    "cleartext": true
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#d97706"
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#d97706",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "LIGHT",
      "backgroundColor": "#d97706",
      "overlaysWebView": false
    }
  }
}
